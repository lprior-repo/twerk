# Locker Parity Gaps Patch - Rust vs Go Implementation
# ======================================================
#
# This patch documents the gaps found when auditing the Rust twerk locker
# implementation against the Go tork implementation.
#
# Files compared:
#   Go: /tmp/tork-go/locker/locker.go, /tmp/tork-go/locker/postgres.go
#   Rust: /home/lewis/src/twerk/locker/lib.rs, /home/lewis/src/twerk/locker/postgres.rs
#
# ==============================================================================
# GAP 1: Connection Never Returned to Pool on Lock Release
# ==============================================================================
#
# SUMMARY: When a lock is successfully acquired in Rust, the connection is
# extracted from PooledClient via into_inner() and never returned to the pool.
# The PooledClient RAII guard is bypassed, so Drop never runs.
#
# GO IMPLEMENTATION (Correct):
#   - tx.Rollback() automatically returns connection to sqlx pool
#   - Connection is properly recycled
#
# RUST IMPLEMENTATION (Broken):
#   acquire_advisory_lock() at line ~415:
#     let pooled = pool.get()?;           // Gets PooledClient (RAII guard)
#     let client = pooled.into_inner();    // BYPASSES Drop! Connection NOT returned
#     // ... client wrapped in PostgresLock
#
#   release_lock() at line ~331:
#     - Only executes ROLLBACK on the connection
#     - Does NOT return connection to pool
#     - Connection is effectively leaked from pool's perspective
#
# EXPECTED FIX:
#   The PostgresLock should not consume the client directly. Instead:
#   1. Store the PooledClient inside PostgresLock (not just the PgClient)
#   2. On release, execute ROLLBACK, then let PooledClient drop to return
#      connection to pool
#
#   OR alternatively:
#   1. Track pool pointer in PostgresLock
#   2. On release, ROLLBACK and explicitly call pool.put(client, created_at)
#
# ==============================================================================
# GAP 2: release_lock Uses Raw Thread Spawn Instead of spawn_blocking
# ==============================================================================
#
# GO IMPLEMENTATION:
#   - Simple function call: l.tx.Rollback()
#
# RUST IMPLEMENTATION (line ~336):
#   let handle = std::thread::spawn(move || {
#       let mut guard = client.lock();
#       let _ = guard.simple_query("ROLLBACK");
#   });
#
#   Box::pin(async move {
#       let _ = tokio::task::spawn_blocking(move || {
#           let _ = handle.join();
#       })
#       .await;
#       Ok(())
#   })
#
# EXPECTED FIX:
#   Replace raw thread spawn with tokio::task::spawn_blocking directly:
#
#   Box::pin(async move {
#       let client = client.clone(); // or pass necessary data
#       tokio::task::spawn_blocking(move || {
#           let mut guard = client.lock();
#           let _ = guard.simple_query("ROLLBACK");
#       }).await?;
#       Ok(())
#   })
#
