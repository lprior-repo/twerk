## GAP 1: Missing Health Check System

The Go implementation has a complete health check system at `/tmp/tork-go/health/health.go` that Rust is missing entirely.

### Go Code (`/tmp/tork-go/health/health.go`):
```go
package health

type HealthIndicator func(ctx context.Context) error

type HealthCheckResult struct {
    Status  string `json:"status"`
    Version string `json:"version"`
}

type HealthCheck struct {
    indicators map[string]HealthIndicator
}

func (b *HealthCheck) WithIndicator(name string, ind HealthIndicator) *HealthCheck {
    name = strings.TrimSpace(name)
    if name == "" {
        panic("health indicator name must not be empty")
    }
    if _, ok := b.indicators[name]; ok {
        panic(fmt.Sprintf("health indicator with name %s already exists", name))
    }
    b.indicators[name] = ind
    return b
}

func NewHealthCheck() *HealthCheck {
    return &HealthCheck{
        indicators: make(map[string]HealthIndicator),
    }
}

func (b *HealthCheck) Do(ctx context.Context) HealthCheckResult {
    for name, ind := range b.indicators {
        if err := ind(ctx); err != nil {
            log.Error().Err(err).Msgf("failed %s healthcheck", name)
            return HealthCheckResult{
                Status:  StatusDown,
                Version: tork.Version,
            }
        }
    }
    return HealthCheckResult{
        Status:  StatusUp,
        Version: tork.Version,
    }
}
```

### Expected Fix:
Create `/home/lewis/src/twerk/tork/health.rs`:

```rust
//! Health check system for Tork.
//!
//! Port of Go `/tmp/tork-go/health/health.go`

use std::collections::HashMap;
use std::sync::Arc;

/// Health indicator function type.
pub type HealthIndicator = Arc<dyn Fn() -> Result<()> + Send + Sync>;

/// Health check result.
#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]
pub struct HealthCheckResult {
    pub status: String,
    pub version: String,
}

/// Health check with registered indicators.
#[derive(Default)]
pub struct HealthCheck {
    indicators: HashMap<String, HealthIndicator>,
}

impl HealthCheck {
    /// Create a new health check.
    pub fn new() -> Self {
        Self {
            indicators: HashMap::new(),
        }
    }

    /// Register a health indicator.
    ///
    /// # Panics
    /// Panics if name is empty or already registered.
    pub fn with_indicator(mut self, name: &str, ind: HealthIndicator) -> Self {
        let name = name.trim();
        if name.is_empty() {
            panic("health indicator name must not be empty");
        }
        if self.indicators.contains_key(name) {
            panic(format!("health indicator with name {} already exists", name));
        }
        self.indicators.insert(name.to_string(), ind);
        self
    }

    /// Perform all health checks.
    ///
    /// Returns `StatusUp` if all indicators pass, `StatusDown` on first failure.
    pub fn do_check(&self) -> HealthCheckResult {
        for (name, ind) in &self.indicators {
            if let Err(e) = ind() {
                tracing::error!(error = %e, "failed {} healthcheck", name);
                return HealthCheckResult {
                    status: STATUS_DOWN.to_string(),
                    version: crate::version::VERSION.to_string(),
                };
            }
        }
        HealthCheckResult {
            status: STATUS_UP.to_string(),
            version: crate::version::VERSION.to_string(),
        }
    }
}

/// Health status constants.
pub const STATUS_UP: &str = "UP";
pub const STATUS_DOWN: &str = "DOWN";
```

