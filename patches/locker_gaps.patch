# GAP 7: hash_key Returns Signed vs Unsigned
# ==============================================================================
#
# GO IMPLEMENTATION (lines ~106-109):
#   func hashKey(key string) int64 {
#       hash := sha256.Sum256([]byte(key))
#       unsigned := binary.BigEndian.Uint64(hash[:8])
#       return int64(unsigned)  // Explicit cast from uint64 to int64
#   }
#
# RUST IMPLEMENTATION (lines ~71-76):
#   pub fn hash_key(key: &str) -> i64 {
#       let result = Sha256::digest(key.as_bytes());
#       i64::from_be_bytes([...])  // Direct bytes to i64
#   }
#
# NOTE: This is actually CORRECT - both interpret the first 8 bytes as a
# big-endian signed 64-bit integer. The Go code uses an intermediate uint64
# but the final int64 conversion preserves the bit pattern identically.
#
