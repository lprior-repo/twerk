  "paths": {
    "/api/v1/triggers": {
      "get": {
        "tags": [
          "Triggers"
        ],
        "summary": "GET /api/v1/triggers",
        "description": "Lists all triggers.\n\n# Errors\nReturns 500 for persistence errors.",
        "operationId": "list_triggers_handler",
        "responses": {
          "200": {
            "description": "List of triggers"
          },
          "500": {
            "description": "Persistence error"
          }
        }
      },
      "post": {
        "tags": [
          "Triggers"
        ],
        "summary": "POST /api/v1/triggers",
        "description": "# Errors\nReturns 201 on success, 400 for validation errors.",
        "operationId": "create_trigger_handler",
        "responses": {
          "201": {
            "description": "Trigger created"
          },
          "400": {
            "description": "Validation error"
          }
        }
      }
    },
    "/api/v1/triggers/{id}": {
      "get": {
        "tags": [
          "Triggers"
        ],
        "summary": "GET /api/v1/triggers/{id}",
        "description": "# Errors\nReturns 404 if trigger not found, 400 if ID format invalid.",
        "operationId": "get_trigger_handler",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Trigger ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Trigger found"
          },
          "400": {
            "description": "Invalid ID format"
          },
          "404": {
            "description": "Trigger not found"
          }
        }
      },
      "put": {
        "tags": [
          "Triggers"
        ],
        "summary": "Handler for `PUT /api/v1/triggers/{id}`.",
        "description": "# Errors\nReturns `ApiError` only for framework-level failures.",
        "operationId": "update_trigger_handler",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Trigger ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Trigger updated"
          },
          "400": {
            "description": "Validation error or invalid request"
          },
          "404": {
            "description": "Trigger not found"
          },
          "409": {
            "description": "Version conflict"
          }
        }
      },
      "delete": {
        "tags": [
          "Triggers"
        ],
        "operationId": "delete_trigger_handler",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Trigger ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Trigger deleted"
          },
          "400": {
            "description": "Invalid ID format"
          },
          "404": {
            "description": "Trigger not found"
          }
        }
      }
    },
    "/health": {
      "get": {
        "tags": [
          "System"
        ],
        "summary": "Health check handler",
        "operationId": "health_handler",
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "503": {
            "description": "Service is unhealthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
