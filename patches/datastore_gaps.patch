## GAP 6: Scheduled job permissions not inserted in Rust

### Go code (postgres/postgres.go:1343-1361):
```go
for _, perm := range sj.Permissions {
    var username *string
    var roleSlug *string
    if perm.Role != nil {
        roleSlug = &perm.Role.Slug
    } else {
        username = &perm.User.Username
    }
    sql := `insert into scheduled_jobs_perms 
              (id,scheduled_job_id,user_id,role_id) 
            values 
              ($1,$2,$3,$4)`
    if _, err := ptx.exec(sql, uuid.NewUUID(), sj.ID, username, roleSlug); err != nil {
        return errors.Wrapf(err, "error inserting job to the db")
    }
}
```

### Rust code (datastore/postgres/mod.rs:1097-1124):
The `create_scheduled_job` implementation does NOT insert permissions into `scheduled_jobs_perms` table.

### Expected fix:
Add permission insertion loop after scheduled job insert in `create_scheduled_job`:
```rust
// Insert scheduled job permissions
if let Some(perms) = &sj.permissions {
    for perm in perms {
        let (user_id, role_id) = match (&perm.user, &perm.role) {
            (Some(u), None) => (u.id.clone(), None),
            (None, Some(r)) => (None, r.id.clone()),
            _ => continue,
        };
        let perm_id = uuid::Uuid::new_v4().to_string().replace('-', "");
        sqlx::query(
            r"
            insert into scheduled_jobs_perms (id, scheduled_job_id, user_id, role_id)
            values ($1, $2, $3, $4)
            ",
        )
        .bind(&perm_id)
        .bind(id)
        .bind(&user_id)
        .bind(&role_id)
        .execute(&self.pool)
        .await?;
    }
}
```

